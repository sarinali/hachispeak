{
  "name": "out-loud-server",
  "version": "1.0.0",
  "description": "Out Loud TTS Server - Menu Bar App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.outloud.tts-server",
    "productName": "Out Loud TTS",
    "mac": {
      "icon": "icon.png",
      "category": "public.app-category.utilities"
    },
    "files": [
      "main.js",
      "icon.png",
      "iconTemplate.png",
      "iconTemplate@2x.png"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
