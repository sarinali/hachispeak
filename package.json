{
  "name": "out-loud",
  "version": "1.0.5",
  "description": "Free, open-source, 100% offline AI text-to-speech server powered by Kokoro-82M.",
  "license": "MIT",
  "homepage": "https://github.com/light-cloud-com/out-loud#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/light-cloud-com/out-loud.git"
  },
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1"
  },
  "scripts": {
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "check": "bun run lint && bun run fmt:check && bun run server:compile",
    "prepare": "husky",
    "server:install": "cd server && bun install",
    "server:compile": "cd server && bun run compile",
    "server:start": "cd server && bun start",
    "extension:chrome:pack": "mkdir -p releases && cd clients/chrome && zip -r ../../releases/out-loud-chrome.zip . -x '*.DS_Store'",
    "extension:test": "curl -s http://127.0.0.1:51730/api/v1/audio/voices | head -c 200",
    "bench": "bun scripts/bench-streaming.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/fluent-ffmpeg": "2.1.27",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.2",
    "globals": "15.15.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.5.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.59.0",
    "vitest": "3.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
