{
  "manifest_version": 3,
  "name": "Out Loud",
  "version": "1.0.0",
  "description": "Read any text aloud with natural voices - offline",
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png"
  },
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_title": "Out Loud",
    "default_icon": {
      "48": "images/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
